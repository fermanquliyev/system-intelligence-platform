{
  "App": {
    "SelfUrl": "https://localhost:44397",
    "AngularUrl": "http://localhost:4200",
    "CorsOrigins": "https://*.SystemIntelligencePlatform.com,http://localhost:4200,",
    "RedirectAllowedUrls": "http://localhost:4200,",
    "DisablePII": false,
    "HealthCheckUrl": "/health-status"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "Enrich": ["FromLogContext"],
    "WriteTo": [
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "File",
              "Args": {
                "path": "Logs/logs.txt"
              }
            }
          ]
        }
      },
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "Console"
            }
          ]
        }
      }
    ]
  },
  "ConnectionStrings": {
    "Default": "postgresql://postgres:postgres@localhost/sip"
  },
  "AuthServer": {
    "Authority": "https://localhost:44397",
    "RequireHttpsMetadata": true,
    "SwaggerClientId": "SystemIntelligencePlatform_Swagger",
    "CertificatePassPhrase": ""
  },
  "StringEncryption": {
    "DefaultPassPhrase": ""
  },
  "Azure": {
    "KeyVault": {
      "VaultUri": ""
    },
    "ServiceBus": {
      "ConnectionString": ""
    },
    "Language": {
      "Endpoint": "",
      "Key": ""
    },
    "Search": {
      "Endpoint": "",
      "Key": "",
      "IndexName": "incidents-index"
    },
    "SignalR": {
      "ConnectionString": ""
    },
    "ApplicationInsights": {
      "ConnectionString": ""
    }
  }}