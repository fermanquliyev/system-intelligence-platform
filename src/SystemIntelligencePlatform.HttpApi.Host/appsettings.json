{
  "App": {
    "SelfUrl": "https://localhost:44397",
    "AngularUrl": "http://localhost:4200",
    "CorsOrigins": "https://*.SystemIntelligencePlatform.com,http://localhost:4200,",
    "RedirectAllowedUrls": "http://localhost:4200,",
    "DisablePII": false,
    "HealthCheckUrl": "/health-status"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "Enrich": ["FromLogContext"],
    "WriteTo": [
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "File",
              "Args": {
                "path": "Logs/logs.txt"
              }
            }
          ]
        }
      },
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "Console"
            }
          ]
        }
      }
    ]
  },
  "ConnectionStrings": {
    "Default": "postgresql://postgres:postgres@localhost/sip"
  },
  "AuthServer": {
    "Authority": "https://localhost:44397",
    "RequireHttpsMetadata": true,
    "SwaggerClientId": "SystemIntelligencePlatform_Swagger",
    "CertificatePassPhrase": ""
  },
  "StringEncryption": {
    "DefaultPassPhrase": ""
  },
  "RabbitMQ": {
    "Host": "localhost",
    "Port": 5672,
    "Username": "guest",
    "Password": "guest",
    "VirtualHost": "/"
  },
  "Search": {
    "Provider": "Database"
  },
  "OpenTelemetry": {
    "Enabled": true
  },
  "AI": {
    "Provider": "Google",
    "Model": "gemma-3-4b-it",
    "ApiKey": "",
    "Endpoint": "https://generativelanguage.googleapis.com/v1beta/models",
    "MaxTokens": 1024,
    "Temperature": 0.2,
    "TimeoutSeconds": 30,
    "MaxRetries": 3,
    "CircuitBreakerFailureThreshold": 5,
    "CircuitBreakerResetSeconds": 60
  }
}