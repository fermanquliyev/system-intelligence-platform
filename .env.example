# Copy to `.env` in the repo root. Docker Compose reads this file for variable substitution.
# Optional: leave AI__ApiKey empty to use only the local (non-LLM) incident analyzer.

AI__Provider=Google
AI__Model=gemma-3-4b-it
AI__ApiKey=

# Log events older than this many days may be deleted by the data retention background job.
# Matches docker-compose substitution: DataRetention__LogRetentionDays
DataRetention__LogRetentionDays=90
